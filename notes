


// SeedDatabase generates 10 users, with sessions, device tokens, and tasks.
func SeedDatabase(db *gorm.DB) error {
	fmt.Println("Starting database seeding...")

	hashedPass, err := bcrypt.GenerateFromPassword([]byte("password123"), bcrypt.DefaultCost)
	if err != nil {
		return fmt.Errorf("failed to hash password: %w", err)
	}

	now := time.Now()

	categories := []task.CategoryType{task.Work, task.Personal, task.Health, task.Finance, task.Learning, task.Home, task.Social, task.Other}
	repeatUnits := []string{"day", "week", "month"}

	randomCategory := func() task.CategoryType {
		return categories[rand.Intn(len(categories))]
	}

	for i := 1; i <= 10; i++ {
		// 1. Create User
		user := auth.User{
			Name:          fmt.Sprintf("User%d", i),
			Surname:       "Test",
			Email:         fmt.Sprintf("user%d@example.com", i),
			PasswordHash:  string(hashedPass),
			PassChangedAt: now,
			IsActive:      true,
			LastLoginAt:   now,
			Timezone:      "UTC",
		}

		if err := db.Create(&user).Error; err != nil {
			return fmt.Errorf("failed to create user %d: %w", i, err)
		}

		// 2. Create Session
		session := auth.Session{
			ID:        uuid.New().String(),
			UserID:    user.UserID,
			TokenHash: uuid.New().String(),
			IpAddress: "127.0.0.1",
			ExpiresAt: now.Add(24 * 30 * time.Hour),
			IsActive:  true,
		}

		if err := db.Create(&session).Error; err != nil {
			return fmt.Errorf("failed to create session for user %d: %w", i, err)
		}

		// 3. Create DeviceToken
		deviceId := fmt.Sprintf("device-id-%d", i)
		appVersion := "1.0.0"
		deviceToken := notification.DeviceToken{
			UserID:     user.UserID,
			SessionID:  session.ID,
			Token:      uuid.New().String(),
			Platform:   "ios",
			DeviceID:   &deviceId,
			AppVersion: &appVersion,
			IsActive:   true,
			LastSeenAt: now,
		}

		if err := db.Create(&deviceToken).Error; err != nil {
			return fmt.Errorf("failed to create device token for user %d: %w", i, err)
		}

		// 4. Create 2 Weekly Tasks
		weekDaysList := []string{"1,3,5", "2,4", "6,0", "1,2,3,4,5"}
		for j := 1; j <= 2; j++ {
			weekDays := weekDaysList[rand.Intn(len(weekDaysList))]
			taskTmpl := task.TaskTemplate{
				UserID:      user.UserID,
				Title:       fmt.Sprintf("Weekly Task %d for User %d", j, i),
				Description: "This is a weekly task generated by seed",
				RepeatType:  "weekly",
				IsActive:    true,
				Category:    randomCategory(),
				WeekDays:    &weekDays,
			}
			if err := db.Create(&taskTmpl).Error; err != nil {
				return fmt.Errorf("failed to create weekly task for user %d: %w", i, err)
			}

			occ := task.TaskOccurrence{
				TaskID:  taskTmpl.ID,
				UserID:  user.UserID,
				DueDate: time.Date(now.Year(), now.Month(), now.Day(), 0, 0, 0, 0, time.UTC),
				Status:  "pending",
			}
			if err := db.Create(&occ).Error; err != nil {
				return fmt.Errorf("failed to create occurrence for weekly task: %w", err)
			}
		}

		// 5. Create 3 Interval Tasks
		for j := 1; j <= 3; j++ {
			rUnit := repeatUnits[rand.Intn(len(repeatUnits))]
			rInterval := rand.Intn(3) + 1
			startDate := time.Date(now.Year(), now.Month(), now.Day(), 0, 0, 0, 0, time.UTC)

			taskTmpl := task.TaskTemplate{
				UserID:         user.UserID,
				Title:          fmt.Sprintf("Interval Task %d for User %d", j, i),
				Description:    "This is an interval task generated by seed",
				RepeatType:     "interval",
				IsActive:       true,
				Category:       randomCategory(),
				RepeatUnit:     &rUnit,
				RepeatInterval: &rInterval,
				StartDate:      &startDate,
			}
			if err := db.Create(&taskTmpl).Error; err != nil {
				return fmt.Errorf("failed to create interval task for user %d: %w", i, err)
			}

			occ := task.TaskOccurrence{
				TaskID:  taskTmpl.ID,
				UserID:  user.UserID,
				DueDate: startDate,
				Status:  "pending",
			}
			if err := db.Create(&occ).Error; err != nil {
				return fmt.Errorf("failed to create occurrence for interval task: %w", err)
			}
		}

		// 6. Create 3 One-shot Tasks
		for j := 1; j <= 3; j++ {
			dueDate := time.Date(now.Year(), now.Month(), now.Day()+j, 0, 0, 0, 0, time.UTC)
			taskTmpl := task.TaskTemplate{
				UserID:      user.UserID,
				Title:       fmt.Sprintf("One-shot Task %d for User %d", j, i),
				Description: "This is a one-shot task generated by seed",
				RepeatType:  "once",
				IsActive:    true,
				Category:    randomCategory(),
				DueDate:     &dueDate,
			}
			if err := db.Create(&taskTmpl).Error; err != nil {
				return fmt.Errorf("failed to create one-shot task for user %d: %w", i, err)
			}

			occ := task.TaskOccurrence{
				TaskID:  taskTmpl.ID,
				UserID:  user.UserID,
				DueDate: dueDate,
				Status:  "pending",
			}
			if err := db.Create(&occ).Error; err != nil {
				return fmt.Errorf("failed to create occurrence for one-shot task: %w", err)
			}
		}
	}

	fmt.Println("Database seeded successfully!")
	return nil
}
